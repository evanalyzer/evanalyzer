    {
      "meta": {
        "name": "Cells",
        "shortDescription": "Cells",
        "description": "Based on the detected nuclei a Voronoi algorithm is used to separete individual cells. The detected cell area is used to find the border of the cells\n1. Measure intensity per cell in your required channels (default Ch0,1 and 2 is measured)",
        "authorFirstName": "EVAnalyzer",
        "authorLastName": "Team",
        "authorOrganization": "evanalyzer.org",
        "creationTime": "2026-06-11T00:00:00Z"
      },
      "pipelineSteps": [
        {
          "enabled": true,
          "command": {
            "type": "voronoi",
            "centers": {
              "VALID": 4
            },
            "centerFilterClasses": [],
            "mask": {
              "VALID": 11
            },
            "maskFilterClasses": [],
            "outputClass": {
              "VALID": 12
            },
            "unit": "px",
            "maxRadius": 0.0,
            "excludeAreasAtTheEdges": false,
            "excludeAreasWithNoCenter": true
          }
        }
      ]
    },
