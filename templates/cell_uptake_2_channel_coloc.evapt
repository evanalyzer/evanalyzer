  "pipelines": [
    {
      "meta": {
        "name": "Nuclei",
        "shortDescription": "Nuclei",
        "description": "1. Set image nucleus channel\n2. Adapt threshold. Recommanded autoTH: Triangle, Moments or Otsu\n3. Define min particle size in \"Classifier\" to filter out small aggregates not connected to Nuclei.",
        "authorFirstName": "EVAnalyzer",
        "authorLastName": "Team",
        "authorOrganization": "evanalyzer.org",
        "creationTime": "2026-06-11T00:00:00Z"
      },
      "pipelineSteps": [
        {
          "enabled": true,
          "command": {
            "type": "rollingBall",
            "radius": 4.0,
            "ballType": "PARABOLOID",
            "preSmooth": false
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "blur",
            "kernelSize": 3
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "blur",
            "kernelSize": 3
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "threshold",
            "thresholds": [
              {
                "method": "TRIANGLE",
                "minThreshold": 200.0,
                "maxThreshold": 65535.0,
                "unit": "bit",
                "objectClassId": 1
              }
            ]
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "watershed",
            "maximumFinderTolerance": 0.5
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "connectedComponents"
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "extractRois",
            "maxObjectsBeforeFail": 100000
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "classifyRois",
            "originSegmentation": [
              1
            ],
            "inputClasses": [],
            "matchHandling": "ADD_OUTPUT_CLASS_IF_MATCH",
            "outputClass": {
              "VALID": 4
            },
            "sizeUnit": "px",
            "minArea": 1000.0,
            "maxArea": 2147483648.0,
            "minCircularity": 0.0,
            "maxCircularity": 1.0,
            "minSolidity": 0.0,
            "maxSolidity": 1.0,
            "minAspectRatio": 0.0,
            "maxAspectRatio": 2147483648,
            "minEccentricity": 0.0,
            "maxEccentricity": 1.0,
            "minFeret": 0.0,
            "maxFeret": 2147483648,
            "allowEdgeTouching": true
          }
        }
      ]
    },
    {
      "meta": {
        "name": "Cell area",
        "shortDescription": "Cell area",
        "description": "Detects the whole brightfield cell area.\n1. Define Brightfield image channel\n2. Adjust TH if needed\n3. Define min particle size in \"Classifier\" to filter out small aggregates.",
        "authorFirstName": "EVAnalyzer",
        "authorLastName": "Team",
        "authorOrganization": "evanalyzer.org",
        "creationTime": "2026-06-11T00:00:00Z"
      },
      "pipelineSteps": [
        {
          "enabled": true,
          "command": {
            "type": "edgeDetectionSobel",
