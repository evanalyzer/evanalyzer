  "pipelines": [
    {
      "meta": {
        "name": "Channel1",
        "shortDescription": "Channel1",
        "description": "1. output class can be renamed in classification tab (ch1@.. can be e.g. GFP@...)\n2. Select  output class\n3. Select EV image channel\n4. Adapt manual threshold\n5. Object can be gated by size/circularity in \"Classifier\"\n",
        "authorFirstName": "EVAnalyzer",
        "authorLastName": "Team",
        "authorOrganization": "evanalyzer.org",
        "creationTime": "2026-06-11T00:00:00Z"
      },
      "pipelineSteps": [
        {
          "enabled": true,
          "command": {
            "type": "rollingBall",
            "radius": 4.0,
            "ballType": "PARABOLOID",
            "preSmooth": false
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "blur",
            "kernelSize": 3
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "blur",
            "kernelSize": 3
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "threshold",
            "thresholds": [
              {
                "method": "MANUAL",
                "minThreshold": 200.0,
                "maxThreshold": 65535.0,
                "unit": "bit",
                "objectClassId": 1
              }
            ]
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "watershed",
            "maximumFinderTolerance": 0.5
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "connectedComponents"
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "extractRois",
            "maxObjectsBeforeFail": 100000
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "classifyRois",
            "originSegmentation": [
              1
            ],
            "inputClasses": [],
            "matchHandling": "ADD_OUTPUT_CLASS_IF_MATCH",
            "outputClass": {
              "VALID": 15
            },
            "sizeUnit": "px",
            "minArea": 5.0,
            "maxArea": 2147483648.0,
            "minCircularity": 0.0,
            "maxCircularity": 1.0,
            "minSolidity": 0.0,
            "maxSolidity": 1.0,
            "minAspectRatio": 0.0,
            "maxAspectRatio": 2147483648,
            "minEccentricity": 0.0,
            "maxEccentricity": 1.0,
            "minFeret": 0.0,
            "maxFeret": 2147483648,
            "allowEdgeTouching": true
          }
        },
        {
          "enabled": true,
          "command": {
            "type": "saveImage",
            "path": "images/${imageName}/ev",
            "source": "IMAGE"
          }
        }
      ]
    },
