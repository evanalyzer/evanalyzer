import { Palette, ScrollView } from "std-widgets.slint";
import { Theme } from "../style.slint";
import { ToolToggleButton } from "../components/toggle_button.slint";
import { VerticalDivider } from "../components/divider.slint";
import {
    ResultsTable,
    ResultsState,
    ResultsViewMode,
    ResultsGroupBy,
    ResultsColumnDef,
    ResultsRow,
    FilterItem,
} from "results_table.slint";
export { ResultsState, ResultsViewMode, ResultsGroupBy, ResultsColumnDef, ResultsRow, FilterItem } from "results_table.slint";


// -- Radio-style option row (used in the group-by popup) ----------------------

component GroupOptionRow inherits TouchArea {
    in property <string> label;
    in property <bool> selected: false;
    // false = radio (single choice), true = checkbox (multi-select)
    in property <bool> checkbox: false;
    height: 26px;
    mouse-cursor: pointer;

    Rectangle {
        background: root.has-hover ? Theme.raised : transparent;
        animate background { duration: 80ms; }

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 6px;
            spacing: 7px;
            alignment: start;

            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 13px;
                    height: 13px;
                    border-radius: root.checkbox ? 2px : 6.5px;
                    border-width: 1.5px;
                    border-color: root.selected ? Theme.accent : Theme.border;
                    background: root.selected ? Theme.accent : transparent;

                    // Checkbox tick
                    if root.selected && root.checkbox: Image {
                        source: @image-url("../icons/regular-black/check.svg");
                        width: 9px;
                        height: 9px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        colorize: white;
                    }
                    // Radio dot
                    if root.selected && !root.checkbox: Rectangle {
                        width: 5px;
                        height: 5px;
                        border-radius: 2.5px;
                        background: white;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }

            Text {
                text: root.label;
                font-size: 11px;
                font-family: Theme.font-mono;
                color: root.selected ? Theme.text-dim : Theme.text-mute;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
    }
}

// -- Toolbar -------------------------------------------------------------------

component ResultsToolbar inherits Rectangle {
    height: 48px;
    background: Theme.bg;

    HorizontalLayout {
        padding-top: 5px;
        padding-left: 4px;
        padding-right: 8px;
        padding-bottom: 5px;
        spacing: 2px;

        // -- Column visibility (funnel icon opens popup) -----------------------
        col-vis-btn := Rectangle {
            width: 36px;
            height: 36px;
            property <bool> col-popup-open: false;

            ToolToggleButton {
                icon: @image-url("../icons/regular-black/funnel.svg");
                clicked => {
                    col-vis-btn.col-popup-open = true;
                    col-filter-popup.show();
                }
            }

            col-filter-popup := PopupWindow {
                x: 0px;
                y: col-vis-btn.height + 2px;
                width: 230px;
                height: 320px;
                close-policy: no-auto-close;

                Rectangle {
                    background: Theme.panel;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: Theme.radius-md;
                    drop-shadow-blur: 12px;
                    drop-shadow-color: #00000036;
                    drop-shadow-offset-y: 4px;
                    clip: true;

                    VerticalLayout {
                        spacing: 0px;

                        // -- Search field --------------------------------------
                        Rectangle {
                            height: 34px;
                            background: Theme.bg;

                            HorizontalLayout {
                                padding: 4px;
                                spacing: 4px;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 26px;
                                    background: Theme.bg;
                                    border-radius: 3px;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    clip: true;

                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 4px;
                                        spacing: 5px;

                                        VerticalLayout {
                                            alignment: center;
                                            Image {
                                                source: @image-url("../icons/regular-black/magnifying-glass.svg");
                                                width: 11px;
                                                height: 11px;
                                                colorize: Theme.text-mute;
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;

                                            col-search-input := TextInput {
                                                width: parent.width;
                                                font-size: 11px;
                                                font-family: Theme.font-mono;
                                                color: Theme.text;
                                                vertical-alignment: center;
                                                edited => {
                                                    ResultsState.column_search_changed(self.text);
                                                }
                                            }

                                            if col-search-input.text == "": Text {
                                                x: 0px;
                                                y: (parent.height - self.height) / 2;
                                                text: "Search…";
                                                font-size: 11px;
                                                color: Theme.text-faint;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border-soft; }

                        // -- (Select All) --------------------------------------
                        col-sel-all-ta := TouchArea {
                            height: 26px;
                            mouse-cursor: pointer;
                            clicked => {
                                if (ResultsState.column_popup_all_checked) {
                                    ResultsState.column_clear_all();
                                } else {
                                    ResultsState.column_select_all();
                                }
                            }

                            Rectangle {
                                background: col-sel-all-ta.has-hover ? Theme.raised : transparent;
                                animate background { duration: 80ms; }

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 6px;
                                    spacing: 7px;
                                    alignment: start;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 13px;
                                            height: 13px;
                                            border-radius: 2px;
                                            border-width: 1.5px;
                                            border-color: ResultsState.column_popup_all_checked ? Theme.accent : Theme.border;
                                            background: ResultsState.column_popup_all_checked ? Theme.accent : transparent;

                                            if ResultsState.column_popup_all_checked: Image {
                                                source: @image-url("../icons/regular-black/check.svg");
                                                width: 9px;
                                                height: 9px;
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                colorize: white;
                                            }
                                        }
                                    }

                                    Text {
                                        text: "(Select All)";
                                        font-size: 11px;
                                        font-family: Theme.font-mono;
                                        font-weight: 600;
                                        color: ResultsState.column_popup_all_checked ? Theme.text-dim : Theme.text-mute;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border-soft; }

                        // -- Item list -----------------------------------------
                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding: 2px;
                                spacing: 0px;

                                for item in (col-vis-btn.col-popup-open ? ResultsState.column_popup : []): col-item-ta := TouchArea {
                                    height: 26px;
                                    mouse-cursor: pointer;
                                    clicked => {
                                        ResultsState.column_label_toggled(item.label);
                                    }

                                    Rectangle {
                                        background: col-item-ta.has-hover ? Theme.raised : transparent;
                                        animate background { duration: 80ms; }

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 6px;
                                            spacing: 7px;
                                            alignment: start;

                                            VerticalLayout {
                                                alignment: center;
                                                Rectangle {
                                                    width: 13px;
                                                    height: 13px;
                                                    border-radius: 2px;
                                                    border-width: 1.5px;
                                                    border-color: item.checked ? Theme.accent : Theme.border;
                                                    background: item.checked ? Theme.accent : transparent;

                                                    if item.checked: Image {
                                                        source: @image-url("../icons/regular-black/check.svg");
                                                        width: 9px;
                                                        height: 9px;
                                                        x: (parent.width - self.width) / 2;
                                                        y: (parent.height - self.height) / 2;
                                                        colorize: white;
                                                    }
                                                }
                                            }

                                            Text {
                                                text: item.label;
                                                font-size: 11px;
                                                font-family: Theme.font-mono;
                                                color: item.checked ? Theme.text-dim : Theme.text-mute;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border-soft; }

                        // -- Done button ---------------------------------------
                        col-done-ta := TouchArea {
                            height: 28px;
                            mouse-cursor: pointer;
                            clicked => {
                                ResultsState.column_filter_apply();
                                col-vis-btn.col-popup-open = false;
                                col-filter-popup.close();
                            }

                            Rectangle {
                                background: col-done-ta.has-hover ? Theme.raised : transparent;
                                animate background { duration: 80ms; }

                                HorizontalLayout {
                                    alignment: center;
                                    Text {
                                        text: "Done";
                                        font-size: 11px;
                                        font-family: Theme.font-sans;
                                        color: Theme.accent;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // -- Group by (stack icon opens popup) ---------------------------------
        group-btn := Rectangle {
            width: 36px;
            height: 36px;

            ToolToggleButton {
                icon: @image-url("../icons/regular-black/stack.svg");
                checked: ResultsState.group_active;
                clicked => {
                    group-popup.show();
                }
            }

            group-popup := PopupWindow {
                x: 0px;
                y: group-btn.height + 2px;
                width: 250px;
                height: 414px;
                close-policy: no-auto-close;

                Rectangle {
                    background: Theme.panel;
                    border-width: 1px;
                    border-color: Theme.border;
                    border-radius: Theme.radius-md;
                    drop-shadow-blur: 12px;
                    drop-shadow-color: #00000036;
                    drop-shadow-offset-y: 4px;
                    clip: true;

                    VerticalLayout {
                        spacing: 0px;

                        // -- "Group by" section header ---------------------
                        Rectangle {
                            height: 26px;
                            background: Theme.bg;
                            Text {
                                x: 8px;
                                text: "Group by";
                                font-size: 11px;
                                font-family: Theme.font-sans;
                                font-weight: 600;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-soft; }

                        GroupOptionRow {
                            label: "None";
                            selected: ResultsState.group_by == ResultsGroupBy.none;
                            clicked => { ResultsState.group_by = ResultsGroupBy.none; }
                        }
                        GroupOptionRow {
                            label: "Image name";
                            selected: ResultsState.group_by == ResultsGroupBy.image;
                            clicked => { ResultsState.group_by = ResultsGroupBy.image; }
                        }
                        GroupOptionRow {
                            label: "Folder name";
                            selected: ResultsState.group_by == ResultsGroupBy.folder;
                            clicked => { ResultsState.group_by = ResultsGroupBy.folder; }
                        }
                        GroupOptionRow {
                            label: "Regex on image name";
                            selected: ResultsState.group_by == ResultsGroupBy.regex;
                            clicked => { ResultsState.group_by = ResultsGroupBy.regex; }
                        }

                        // -- Regex pattern input ---------------------------
                        Rectangle {
                            height: 36px;
                            background: Theme.bg;
                            HorizontalLayout {
                                padding: 4px;
                                padding-left: 26px;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 26px;
                                    background: ResultsState.group_by == ResultsGroupBy.regex ? Theme.bg : Theme.panel;
                                    border-radius: 3px;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    clip: true;
                                    opacity: ResultsState.group_by == ResultsGroupBy.regex ? 1.0 : 0.5;

                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 4px;

                                        Rectangle {
                                            horizontal-stretch: 1;

                                            regex-input := TextInput {
                                                width: parent.width;
                                                font-size: 11px;
                                                font-family: Theme.font-mono;
                                                color: Theme.text;
                                                vertical-alignment: center;
                                                enabled: ResultsState.group_by == ResultsGroupBy.regex;
                                                text: ResultsState.group_regex;
                                                edited => {
                                                    ResultsState.group_regex = self.text;
                                                }
                                            }

                                            if regex-input.text == "": Text {
                                                x: 0px;
                                                y: (parent.height - self.height) / 2;
                                                text: "^([A-Z]\\d+)_";
                                                font-size: 11px;
                                                font-family: Theme.font-mono;
                                                color: Theme.text-faint;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // -- "Aggregate" section header --------------------
                        Rectangle {
                            height: 26px;
                            background: Theme.bg;
                            Text {
                                x: 8px;
                                text: "Aggregate";
                                font-size: 11px;
                                font-family: Theme.font-sans;
                                font-weight: 600;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { height: 1px; background: Theme.border-soft; }

                        HorizontalLayout {
                            padding: 4px;
                            spacing: 0px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                GroupOptionRow {
                                    label: "Min";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_min;
                                    clicked => { ResultsState.group_agg_min = !ResultsState.group_agg_min; }
                                }
                                GroupOptionRow {
                                    label: "Max";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_max;
                                    clicked => { ResultsState.group_agg_max = !ResultsState.group_agg_max; }
                                }
                                GroupOptionRow {
                                    label: "Average";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_avg;
                                    clicked => { ResultsState.group_agg_avg = !ResultsState.group_agg_avg; }
                                }
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                GroupOptionRow {
                                    label: "Median";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_median;
                                    clicked => { ResultsState.group_agg_median = !ResultsState.group_agg_median; }
                                }
                                GroupOptionRow {
                                    label: "Std. dev.";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_stdev;
                                    clicked => { ResultsState.group_agg_stdev = !ResultsState.group_agg_stdev; }
                                }
                                GroupOptionRow {
                                    label: "Sum";
                                    checkbox: true;
                                    selected: ResultsState.group_agg_sum;
                                    clicked => { ResultsState.group_agg_sum = !ResultsState.group_agg_sum; }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.border-soft; }

                        // -- Apply button ----------------------------------
                        apply-ta := TouchArea {
                            height: 30px;
                            mouse-cursor: pointer;
                            clicked => {
                                ResultsState.group_apply();
                                group-popup.close();
                            }

                            Rectangle {
                                background: apply-ta.has-hover ? Theme.raised : transparent;
                                animate background { duration: 80ms; }
                                Text {
                                    text: "Apply";
                                    font-size: 11px;
                                    font-family: Theme.font-sans;
                                    color: Theme.accent;
                                    font-weight: 500;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        VerticalDivider { }

        // -- View mode ---------------------------------------------------------
        ToolToggleButton {
            icon: @image-url("../icons/regular-black/table.svg");
            checked: ResultsState.view_mode == ResultsViewMode.table;
            clicked => {
                ResultsState.view_mode = ResultsViewMode.table;
            }
        }

        ToolToggleButton {
            icon: @image-url("../icons/regular-black/chart-bar.svg");
            checked: ResultsState.view_mode == ResultsViewMode.chart;
            enabled: false;
            clicked => {
                ResultsState.view_mode = ResultsViewMode.chart;
            }
        }

        VerticalDivider { }

        // -- Sort direction ----------------------------------------------------
        ToolToggleButton {
            icon: ResultsState.sort_ascending ? @image-url("../icons/regular-black/sort-ascending.svg") : @image-url("../icons/regular-black/sort-descending.svg");
            enabled: ResultsState.sort_column_id != "";
            clicked => {
                ResultsState.sort_ascending = !ResultsState.sort_ascending;
                ResultsState.sort_requested(ResultsState.sort_column_id, ResultsState.sort_ascending);
            }
        }

        // -- Copy to clipboard -------------------------------------------------
        ToolToggleButton {
            icon: @image-url("../icons/regular-black/clipboard.svg");
            clicked => {
                ResultsState.copy_to_clipboard();
            }
        }

        // -- Spacer ------------------------------------------------------------
        Rectangle {
            horizontal-stretch: 1;
        }

        VerticalDivider { }

        // -- Export ------------------------------------------------------------
        ToolToggleButton {
            icon: @image-url("../icons/regular-black/file-csv.svg");
            clicked => {
                ResultsState.export_csv();
            }
        }

        ToolToggleButton {
            icon: @image-url("../icons/regular-black/file-xls.svg");
            clicked => {
                ResultsState.export_xlsx();
            }
        }
    }
}

// -- Status footer -------------------------------------------------------------

component ResultsStatusBar inherits Rectangle {
    height: 32px;

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 1px;
            background: Theme.border;
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 12px;
            vertical-stretch: 1;

            Text {
                text: ResultsState.rows.length == 1 ? "1 row" : ResultsState.rows.length + " rows";
                font-size: 11px;
                font-family: Theme.font-mono;
                color: Theme.text-mute;
                vertical-alignment: center;
            }

            if ResultsState.filter_active: VerticalLayout {
                alignment: center;

                filter-badge-ta := TouchArea {
                    height: 16px;
                    mouse-cursor: pointer;
                    clicked => { ResultsState.clear_all_filters(); }

                    Rectangle {
                        border-radius: 3px;
                        background: filter-badge-ta.has-hover ? Theme.accent : Theme.accent-dim;
                        border-width: 1px;
                        border-color: Theme.accent;
                        animate background { duration: 80ms; }

                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 4px;
                            spacing: 3px;
                            alignment: center;

                            Text {
                                text: "filtered";
                                font-size: 10px;
                                font-family: Theme.font-mono;
                                color: filter-badge-ta.has-hover ? white : Theme.accent;
                                vertical-alignment: center;
                                animate color { duration: 80ms; }
                            }

                            Image {
                                source: @image-url("../icons/regular-black/x.svg");
                                width: 8px;
                                height: 8px;
                                colorize: filter-badge-ta.has-hover ? white : Theme.accent;
                                animate colorize { duration: 80ms; }
                            }
                        }
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            if ResultsState.selected_roi_id != 0: Text {
                text: "ROI \{ResultsState.selected_roi_id}";
                font-size: 11px;
                font-family: Theme.font-mono;
                color: Theme.accent;
                vertical-alignment: center;
            }

            if ResultsState.sort_column_id != "": Text {
                text: "sorted by \{ResultsState.sort_column_id}";
                font-size: 11px;
                color: Theme.text-mute;
                vertical-alignment: center;
            }
        }
    }
}

// -- Window --------------------------------------------------------------------

export component ResultsWindow inherits Window {
    title: "Results - EVAnalyzer";
    preferred-width: 1100px;
    preferred-height: 680px;
    min-width: 600px;
    min-height: 300px;
    background: Theme.bg;

    init => {
        Palette.color-scheme = ColorScheme.light;
    }

    VerticalLayout {
        padding: 0;
        spacing: 0;

        ResultsToolbar { }

        Rectangle {
            height: 1px;
            background: Theme.border;
        }

        ResultsTable {
            vertical-stretch: 1;
            background: Theme.panel;
        }

        ResultsStatusBar { }
    }
}
