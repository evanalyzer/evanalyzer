import { BaseDialog } from "dialog_base.slint";
import { Button } from "std-widgets.slint";
import {
    Palette,
} from "std-widgets.slint";
import {
    GlobalAppState,
    DialogType,
} from "../state.slint";


import { RoiListState } from "../editor/roi_list_panel.slint";

export component ConfirmDeleteRoiDialog inherits BaseDialog {
    title-text: "Delete Region of Interest";
    icon: "⚠️";
    main-height: 260px;
    main-width: 440px;

    VerticalLayout {
        spacing: 12px;
        Text {
            text: "This action cannot be undone. Deleting the selected region of interest.";
            wrap: word-wrap;
            color: Palette.foreground;
            font-size: 14px;
            font-weight: 500;
        }

        Text {
            text: "Delete region of interest \{RoiListState.selected_roi.id}?";
            wrap: word-wrap;
            color: Palette.foreground.with-alpha(0.5);
            font-size: 13px;
        }

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: end;

            Button {
                text: "Cancel";
                primary: true;
                width: 80px;
                clicked => {
                    GlobalAppState.active_dialog = DialogType.none;
                }
            }

            Button {
                text: "Delete";
                width: 100px;
                clicked => {
                    GlobalAppState.active_dialog = DialogType.none;
                    RoiListState.roi_delete(RoiListState.selected_roi.id);
                    RoiListState.selected_roi = { };
                }
            }
        }
    }
}
