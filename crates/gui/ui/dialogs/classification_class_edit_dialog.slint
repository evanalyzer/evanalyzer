import {
    Button,
    LineEdit,
    ComboBox,
    SpinBox,
    VerticalBox,
    HorizontalBox,
    Palette,
    CheckBox,
    ScrollView,
} from "std-widgets.slint";
import { DialogType, GlobalAppState } from "../state.slint";
import { Theme } from "../style.slint";
import { AppButton } from "../components/app_button.slint";



export struct ClassSettingsSlint {
    class_id: int,
    name: string,
    notes: string,
    color: color,
}

export global ClassificationSettingsState {
    in-out property <ClassSettingsSlint> settings;
    callback apply_classification_settings(ClassSettingsSlint);
    public function reset_to_zero() {
        self.settings.class-id = -1;
        self.settings.name = "";
        self.settings.notes = "";
        self.settings.color = #FF00FF;
    }
}

component ColorTile inherits Rectangle {
    in property <color> item_color;
    property <bool> is_selected: ClassificationSettingsState.settings.color == item_color;
    width: 16px;
    height: 16px;
    background: item_color;
    border-radius: 4px;

    border-width: is_selected ? 3px : 1px;
    border-color: is_selected ? Palette.accent-background : Palette.border.darker(20%);

    TouchArea {
        clicked => {
            ClassificationSettingsState.settings.color = item_color;
        }
    }
}

export component ClassEditDialog inherits Rectangle {
    background: Theme.modal-overlay;

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 680px;
        height: 600px;
        background: Theme.panel;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-color: Theme.shadow;
        drop-shadow-blur: 40px;
        drop-shadow-offset-y: 18px;
        clip: true;

        VerticalLayout {
            spacing: 0;

            Rectangle {
                height: 56px;
                background: Theme.panel;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 16px;
                    spacing: 12px;
                    alignment: stretch;

                    Text {
                        text: "Class Settings";
                        color: Theme.text;
                        font-size: 15px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 5px;
                        background: close-ta.has-hover ? Theme.raised : transparent;
                        Text {
                            text: "✕";
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        close-ta := TouchArea {
                            clicked => {
                                GlobalAppState.active-dialog = DialogType.none;
                                ClassificationSettingsState.reset_to_zero();
                            }
                        }
                    }
                }

                Rectangle {
                    x: 0;
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Theme.border-soft;
                }
            }

            Rectangle {
                vertical-stretch: 1;
                VerticalLayout {
                    padding: 20px;
                    spacing: 15px;
                    HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Name:";
                                    vertical-alignment: center;
                                    width: 110px;
                                }

                                LineEdit {
                                    placeholder-text: "e.g. FITC-Cell";
                                    text <=> ClassificationSettingsState.settings.name;
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Notes:";
                                    vertical-alignment: center;
                                    width: 110px;
                                }

                                LineEdit {
                                    placeholder-text: "Optional description...";
                                    text <=> ClassificationSettingsState.settings.notes;
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Color:";
                                    font-weight: 700;
                                    width: 110px;
                                }

                                GridLayout {
                                    spacing: 8px;
                                    Row {
                                        for c in [
                                            #FF00FF,
                                            #00FFFF,
                                            #00FF00,
                                            #FFFF00,
                                            #FF3333,
                                            #3366FF,
                                            #FF9900,
                                            #ADFF2F,
                                            #00FA9A,
                                            #87CEFA,
                                            #FF66CC
                                        ]: ColorTile {
                                            item_color: c;
                                        }
                                    }

                                    Row {
                                        for c in [
                                            #FFD700,
                                            #FF4500,
                                            #FF69B4,
                                            #F08080,
                                            #FFA07A,
                                            #DA70D6,
                                            #FF007F,
                                            #FFCC00,
                                            #EEDD82,
                                            #BC8F8F,
                                            #FF8C00
                                        ]: ColorTile {
                                            item_color: c;
                                        }
                                    }

                                    Row {
                                        for c in [
                                            #00CED1,
                                            #1E90FF,
                                            #9370DB,
                                            #40E0D0,
                                            #7B68EE,
                                            #48D1CC,
                                            #00BFFF,
                                            #AFEEEE,
                                            #B0C4DE,
                                            #66CDAA,
                                            #9932CC
                                        ]: ColorTile {
                                            item_color: c;
                                        }
                                    }

                                    Row {
                                        for c in [
                                            #FFCCFF,
                                            #99FFFF,
                                            #FFE4B5,
                                            #EEE8AA,
                                            #CCFFCC,
                                            #E6E6FA,
                                            #FFFAC8,
                                            #F0FFF0,
                                            #F5FFFA,
                                            #F0F8FF,
                                            #FFFFFF
                                        ]: ColorTile {
                                            item_color: c;
                                        }
                                    }
                                }
                            }

                    Rectangle {
                        vertical-stretch: 1;
                    }
                }
            }

            Rectangle {
                height: 56px;
                background: Theme.bg;
                border-color: Theme.border-soft;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 16px;
                    spacing: 12px;
                    alignment: end;

                    AppButton {
                        text: "Cancel";
                        clicked => {
                            GlobalAppState.active-dialog = DialogType.none;
                            ClassificationSettingsState.reset_to_zero();
                        }
                    }

                    AppButton {
                        text: "Apply Settings";
                        primary: true;
                        clicked => {
                            ClassificationSettingsState.apply_classification_settings(ClassificationSettingsState.settings);
                            GlobalAppState.active-dialog = DialogType.none;
                        }
                    }
                }
            }
        }
    }
}
