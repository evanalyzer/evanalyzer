import { BaseDialog } from "dialog_base.slint";
import { Button } from "std-widgets.slint";
import {
    Palette,
} from "std-widgets.slint";
import {
    GlobalAppState,
    DialogType,
} from "../state.slint";
import {
    ImagesListState,
} from "../editor/images_list_panel.slint";


export component ImageMissingDialog inherits BaseDialog {
    title-text: "Images Missing";
    icon: "⚠️";
    main-height: 260px;
    main-width: 440px;

    VerticalLayout {
        spacing: 12px;
        Text {
            text: "The project image files could not be located. They may have been moved, renamed, or the drive is disconnected.";
            wrap: word-wrap;
            color: Palette.foreground;
            font-size: 14px;
            font-weight: 500;
        }

        Text {
            text: "Would you like to search for them or select a new root folder?";
            wrap: word-wrap;
            color: Palette.foreground.with-alpha(0.5);
            font-size: 13px;
        }

        Rectangle {
            background: Palette.background.darker(0.2);
            border-radius: 4px;
            Text {
                text: ImagesListState.act_image_root_dir;
                font-family: "monospace";
                font-size: 11px;
                color: Palette.accent-background;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: end;
            Button {
                text: "Search";
                primary: true;
                width: 100px;
                clicked => {
                    GlobalAppState.active_dialog = DialogType.none;
                    ImagesListState.new_image_root_folder_clicked();
                }
            }

            Button {
                text: "Select Folder";
                width: 130px;
                clicked => {
                    GlobalAppState.active_dialog = DialogType.none;
                    ImagesListState.open_images_folder_clicked();
                }
            }

            Button {
                text: "Cancel";
                width: 80px;
                clicked => {
                    GlobalAppState.active_dialog = DialogType.none;
                }
            }
        }
    }
}
