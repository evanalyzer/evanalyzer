// project_template_dialog.slint
// EVAnalyzer - "New from Project Template" dialog.
//
// Opens from File > New from Template…. Lets the user pick one of the
// project templates found in the user/app templates folders. Confirming
// replaces the classification, plate and pipeline settings of the
// currently open project with the ones from the selected template.
//
// Layout (880 x 560, centered modal):
//
//   ┌------------------------------------------------------------------┐
//   │  New from Project Template                                   ✕   │   ← header (44)
//   ├----------------------------┬-------------------------------------┤
//   │ □ Nucleus Counting          │   Nucleus Counting                  │
//   │ □ Cell Migration            │   ------------------------------    │
//   │ □ Wound Healing             │   Counts and measures nuclei in...  │   ← list  +  detail
//   │                             │                                     │     pane (split)
//   │                             │   Author        Jane Doe            │
//   │                             │   Organization  Acme Labs           │
//   │                             │   Pipelines     2                   │
//   ├----------------------------┴-------------------------------------┤
//   │                                       [ Cancel ] [ Use Template ] │   ← footer (52)
//   └------------------------------------------------------------------┘
//
// Host wires:
//   - templates : [ProjectTemplateDef]
//   confirm(int)  -> apply this template to the current project
//   cancel().

import { ScrollView } from "std-widgets.slint";
import { AppButton } from "../components/app_button.slint";
import { Theme } from "../style.slint";

export struct ProjectTemplateDef {
    id: int,
    name: string,
    short-description: string,
    description: string,
    author: string,
    organization: string,
    pipeline-count: int,
}

export global ProjectTemplateState {
    in property <[ProjectTemplateDef]> templates;
    in property <ProjectTemplateDef> detail;
    in property <bool> has-detail;
    in-out property <int> selected-id: -1;

    callback select(int);
    callback confirm(int);
    callback cancel();
}

// ---------- Local visual constants ----------

global ProjectTemplateStyle {
    out property <length> modal-w: 880px;
    out property <length> modal-h: 560px;
    out property <length> list-col-w: 320px;
    out property <length> row-h: 48px;
    out property <length> radius: 10px;
}

// ---------- One row in the template list ----------

component ProjectTemplateRow inherits Rectangle {
    in property <ProjectTemplateDef> tmpl;
    in property <bool> selected: false;
    callback clicked;
    callback double-clicked;

    height: ProjectTemplateStyle.row-h;
    background: selected ? Theme.raised : (ta.has-hover ? Theme.bg.with-alpha(0.5) : transparent);
    border-radius: 6px;
    border-width: 1px;
    border-color: selected ? Theme.border : transparent;

    // accent stripe
    Rectangle {
        x: 4px;
        y: 6px;
        width: 3px;
        height: parent.height - 12px;
        background: Theme.accent;
        border-radius: 1.5px;
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 10px;
        spacing: 10px;
        alignment: stretch;

        // icon glyph
        Rectangle {
            width: 28px;
            height: 28px;
            y: (parent.height - 28px) / 2;
            border-radius: 5px;
            background: Theme.bg;
            border-width: 1px;
            border-color: Theme.border-soft;
            Text {
                text: "📦";
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // name + summary
        VerticalLayout {
            alignment: center;
            spacing: 1px;
            horizontal-stretch: 1;
            Text {
                text: tmpl.name;
                color: Theme.text;
                font-size: 12.5px;
                font-weight: 500;
                overflow: elide;
            }

            Text {
                text: tmpl.short-description;
                color: Theme.text-mute;
                font-size: 10.5px;
                font-family: Theme.font-mono;
                overflow: elide;
            }
        }
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
        double-clicked => {
            root.double-clicked();
        }
    }
}

// ---------- Detail pane (right side) ----------

component ProjectTemplateDetailPane inherits Rectangle {
    in property <ProjectTemplateDef> tmpl;
    in property <bool> has-selection: false;

    background: Theme.bg;

    if !has-selection: VerticalLayout {
        alignment: center;
        spacing: 10px;
        Text {
            text: "◇";
            color: Theme.text-faint;
            font-size: 28px;
            horizontal-alignment: center;
        }

        Text {
            text: "Pick a template";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }
    }

    if has-selection: VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 20px;
        padding-bottom: 20px;
        spacing: 16px;

        // Category eyebrow
        HorizontalLayout {
            spacing: 6px;
            alignment: start;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 1.5px;
                background: Theme.accent;
                y: (parent.height - 6px) / 2;
            }

            Text {
                text: "PROJECT TEMPLATE";
                color: Theme.accent;
                font-size: 10px;
                font-weight: 600;
                letter-spacing: 0.6px;
                vertical-alignment: center;
            }
        }

        // Title
        Text {
            text: tmpl.name;
            color: Theme.text;
            font-size: 20px;
            font-weight: 600;
        }

        // Summary
        Text {
            text: tmpl.short-description;
            color: Theme.text-dim;
            font-size: 12.5px;
            wrap: word-wrap;
        }

        // Divider
        Rectangle {
            height: 1px;
            background: Theme.border-soft;
        }

        // Description body
        Text {
            text: tmpl.description;
            color: Theme.text-dim;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle {
            vertical-stretch: 1;
        }   // spacer

        // Footer metadata
        Rectangle {
            height: 1px;
            background: Theme.border-soft;
        }

        VerticalLayout {
            spacing: 4px;
            if tmpl.author != "": HorizontalLayout {
                spacing: 8px;
                alignment: space-between;
                Text {
                    text: "Author";
                    color: Theme.text-mute;
                    font-size: 10.5px;
                }

                Text {
                    text: tmpl.author;
                    color: Theme.text-dim;
                    font-size: 10.5px;
                    font-family: Theme.font-mono;
                    overflow: elide;
                }
            }

            if tmpl.organization != "": HorizontalLayout {
                spacing: 8px;
                alignment: space-between;
                Text {
                    text: "Organization";
                    color: Theme.text-mute;
                    font-size: 10.5px;
                }

                Text {
                    text: tmpl.organization;
                    color: Theme.text-dim;
                    font-size: 10.5px;
                    font-family: Theme.font-mono;
                    overflow: elide;
                }
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: space-between;
                Text {
                    text: "Pipelines";
                    color: Theme.text-mute;
                    font-size: 10.5px;
                }

                Text {
                    text: "\{tmpl.pipeline-count}";
                    color: Theme.text-faint;
                    font-size: 10.5px;
                    font-family: Theme.font-mono;
                }
            }
        }
    }
}

// ===========================================================================
// Main dialog
// ===========================================================================

export component ProjectTemplateDialog inherits Rectangle {
    background: Theme.modal-overlay;

    TouchArea {
        clicked => {
            ProjectTemplateState.cancel();
        }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: ProjectTemplateStyle.modal-w;
        height: ProjectTemplateStyle.modal-h;
        background: Theme.panel;
        border-radius: ProjectTemplateStyle.radius;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-color: Theme.shadow;
        drop-shadow-blur: 40px;
        drop-shadow-offset-y: 18px;
        clip: true;

        // Eat clicks so the scrim TouchArea doesn't fire when clicking inside.
        TouchArea { }

        forward-focus: kbd;
        kbd := FocusScope {
            key-pressed(e) => {
                if e.text == Key.Escape {
                    ProjectTemplateState.cancel();
                    return accept;
                }
                if e.text == Key.Return && ProjectTemplateState.selected-id != -1 {
                    ProjectTemplateState.confirm(ProjectTemplateState.selected-id);
                    return accept;
                }
                return reject;
            }
        }

        VerticalLayout {
            spacing: 0;

            // ---------- 1. Header ----------
            Rectangle {
                height: 44px;
                background: Theme.panel;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 12px;
                    spacing: 12px;
                    alignment: stretch;

                    VerticalLayout {
                        alignment: center;
                        spacing: 0;
                        Text {
                            text: "New from Project Template";
                            color: Theme.text;
                            font-size: 13.5px;
                            font-weight: 600;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        width: 28px;
                        height: 28px;
                        y: (parent.height - 28px) / 2;
                        border-radius: 5px;
                        background: close-ta.has-hover ? Theme.raised : transparent;
                        Text {
                            text: "✕";
                            color: Theme.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        close-ta := TouchArea {
                            clicked => {
                                ProjectTemplateState.cancel();
                            }
                        }
                    }
                }

                Rectangle {
                    x: 0;
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Theme.border-soft;
                }
            }

            // ---------- 2. Body - split list + detail ----------
            Rectangle {
                vertical-stretch: 1;
                HorizontalLayout {
                    spacing: 0;
                    alignment: stretch;

                    // LIST
                    Rectangle {
                        width: ProjectTemplateStyle.list-col-w;
                        background: Theme.panel;

                        ScrollView {
                            VerticalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                padding-top: 8px;
                                padding-bottom: 12px;
                                spacing: 0;

                                if ProjectTemplateState.templates.length == 0: VerticalLayout {
                                    padding-top: 60px;
                                    spacing: 10px;
                                    Text {
                                        text: "No project templates found";
                                        color: Theme.text-dim;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }

                                    Text {
                                        text: "Save a project as template to see it here";
                                        color: Theme.text-mute;
                                        font-size: 10.5px;
                                        font-family: Theme.font-mono;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }

                                for t in ProjectTemplateState.templates: ProjectTemplateRow {
                                    tmpl: t;
                                    selected: t.id == ProjectTemplateState.selected-id;
                                    clicked => {
                                        ProjectTemplateState.selected-id = t.id;
                                        ProjectTemplateState.select(t.id);
                                    }
                                    double-clicked => {
                                        ProjectTemplateState.confirm(t.id);
                                    }
                                }
                            }
                        }
                    }

                    // Splitter
                    Rectangle {
                        width: 1px;
                        background: Theme.border-soft;
                    }

                    // DETAIL
                    ProjectTemplateDetailPane {
                        horizontal-stretch: 1;
                        tmpl: ProjectTemplateState.detail;
                        has-selection: ProjectTemplateState.has-detail;
                    }
                }
            }

            // ---------- 3. Footer ----------
            Rectangle {
                height: 52px;
                background: Theme.bg;
                border-color: Theme.border-soft;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 16px;
                    spacing: 14px;
                    alignment: stretch;

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: "Replaces the current pipelines, classes and plate settings";
                        color: Theme.text-mute;
                        font-size: 10.5px;
                        vertical-alignment: center;
                    }

                    AppButton {
                        text: "Cancel";
                        clicked => {
                            ProjectTemplateState.cancel();
                        }
                    }

                    AppButton {
                        text: "Use Template";
                        primary: true;
                        opacity: ProjectTemplateState.selected-id != -1 ? 1.0 : 0.5;
                        clicked => {
                            if ProjectTemplateState.selected-id != -1 {
                                ProjectTemplateState.confirm(ProjectTemplateState.selected-id);
                            }
                        }
                    }
                }
            }
        }
    }
}
