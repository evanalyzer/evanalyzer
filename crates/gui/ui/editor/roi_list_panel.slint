import {
    Button,
    VerticalBox,
    ListView,
    Spinner,
    Palette,
} from "std-widgets.slint";
import { Theme } from "../style.slint";
import { GlobalAppState } from "../state.slint";
import { DialogType, ChannelState } from "../state.slint";

export struct RoiItemDataSlint {
    id: int,
    name: string,
    display_color: color,
    display_name: string,
    class_names: [string],
    class_colors: [color],
    class_ids: [int],
    label_name: string,
    label_id: int,
    // Metrics – only populated for selected_roi (empty string = not available)
    area: int,
    area_nm2: string,           // area in nm², formatted; empty string = not available
    intensities: [string],      // sum intensity per channel; empty string = not available
    intensity_avgs: [string],   // mean intensity per channel; parallel to intensities
    circularity: string,
    // Count of ROIs sharing the same segmentation label – populated for all rows
    label_count: int,
}

export global RoiListState {
    in-out property <bool> is_scanning: false;
    in-out property <int> scroll_to_roi_index: -1;
    in property <[RoiItemDataSlint]> roi_list: [
        {
            id: 1,
            name: "Annotation",
            display_color: #ff0000,
            display_name: "roi_1",
            class_names: ["Nucleus"],
            class_colors: [#0066ff],
            class_ids: [0],
            label_name: "Nucleus",
            label_id: 0,
            area: 1234,
            intensities: ["128.4", "64.0"],
            intensity_avgs: ["12.8", "6.4"],
            circularity: "0.92",
            label_count: 1,
        },
        {
            id: 2,
            name: "Annotation",
            display_color: #00ff00,
            display_name: "roi_2",
            class_names: ["Cytoplasm", "Membrane", "Artifact", "Background"],
            class_colors: [#ff6600, #ffff00, #00ffff, #cccccc],
            class_ids: [1, 2, 3, 4],
            label_name: "Multi-class",
            label_id: 1,
            area: 5678,
            intensities: ["64.2", "32.1"],
            intensity_avgs: ["6.4", "3.2"],
            circularity: "0.71",
            label_count: 2,
        },
        {
            id: 3,
            name: "Annotation",
            display_color: #ff0000,
            display_name: "roi_3",
            class_names: [],
            class_colors: [],
            class_ids: [],
            label_name: "Multi-class",
            label_id: 1,
            area: 0,
            intensities: [],
            intensity_avgs: [],
            circularity: "",
            label_count: 2,
        }
    ];

    in-out property <RoiItemDataSlint> selected_roi;

    callback roi_selected(int);
    callback roi_copy(int);
    callback roi_edit(int);
    callback roi_delete(int);
    callback roi_add_class(int);
    callback roi_remove_class(int, int);
}

// ----------------------------------------------------------
// Ghost icon button – same pattern as classification_panel
component ActionButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked;

    width: 28px;
    height: 28px;
    border-radius: 5px;
    opacity: root.enabled ? 1.0 : 0.35;
    background: root.enabled && ta.has-hover ? Theme.raised : transparent;
    animate background { duration: 100ms; }

    Image {
        source: root.icon;
        width: 13px;
        height: 13px;
        colorize: ta.has-hover && root.enabled ? Theme.text : Theme.text-dim;
        animate colorize { duration: 100ms; }
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// ----------------------------------------------------------
// Compact 32 px row – kept lean for large lists
component RoiListRow inherits Rectangle {
    in property <RoiItemDataSlint> data;
    in property <bool> selected;
    callback row_clicked;

    height: 32px;

    row_ta := TouchArea {
        clicked => {
            root.row_clicked();
        }
    }

    Rectangle {
        x: 2px;
        y: 1px;
        width: parent.width - 4px;
        height: parent.height - 2px;
        border-radius: Theme.radius-md;
        background: root.selected ? Theme.list-select-row-bg : (row_ta.has-hover ? Theme.raised : transparent);
        border-width: 1px;
        border-color: root.selected ? Theme.list-select-row-border-color : transparent;
        animate background { duration: 80ms; }

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 8px;
            alignment: stretch;

            // Stacked color swatches (up to 4)
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 27px;
                    height: 12px;

                    for class_color[index] in data.class_colors: Rectangle {
                        visible: index < 4;
                        width: 12px;
                        height: 12px;
                        border-radius: 3px;
                        background: class_color;
                        x: index * 5px;
                    }

                    // Fallback single swatch when no classes defined
                    Rectangle {
                        visible: data.class_colors.length == 0;
                        width: 12px;
                        height: 12px;
                        border-radius: 3px;
                        background: data.display-color;
                        x: 0px;
                    }
                }
            }

            // Primary label
            Text {
                text: data.label_name;
                font-size: 13px;
                color: root.selected ? Theme.text-bright : Theme.text;
                font-weight: root.selected ? 500 : 400;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }

            // Mono chip: label_count (how many ROIs share this label)
            VerticalLayout {
                alignment: center;
                Rectangle {
                    height: 16px;
                    min-width: 24px;
                    border-radius: 3px;
                    background: root.selected ? rgba(255, 255, 255, 0.06) : transparent;
                    HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 5px;
                        Text {
                            text: data.label_count;
                            font-size: 10px;
                            font-family: Theme.font-mono;
                            color: Theme.text-mute;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }
    }
}

// ----------------------------------------------------------
export component RoiListPanel inherits Rectangle {

    VerticalBox {
        spacing: 12px;
        padding: Theme.panel-content-padding;

        // ----- HEADER -----
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "Region of Interests";
                font-size: 14px;
                font-weight: 600;
                color: Theme.text;
                vertical-alignment: center;
            }

            Text {
                text: RoiListState.roi_list.length == 1 ? "1 ROI" : RoiListState.roi_list.length + " ROIs";
                font-size: 11px;
                font-family: Theme.font-mono;
                color: Theme.text-mute;
                vertical-alignment: center;
            }
        }

        // ----- ROI LIST -----
        Rectangle {
            vertical-stretch: 1;

            // Mirror global to react to viewport-driven selection changes
            property <int> scroll_index: RoiListState.scroll_to_roi_index;
            changed scroll_index => {
                if (RoiListState.scroll_to_roi_index >= 0) {
                    roi_listview.viewport-y = Math.clamp(
                        -(RoiListState.scroll_to_roi_index * 32px) + roi_listview.height / 2 - 16px,
                        roi_listview.height - roi_listview.viewport-height,
                        0px
                    );
                }
            }

            roi_listview := ListView {
                width: 100%;
                height: 100%;
                horizontal-scrollbar-policy: always-off;

                for data in RoiListState.roi_list: RoiListRow {
                    data: data;
                    selected: RoiListState.selected_roi.id == data.id;

                    row_clicked => {
                        if (data.id == RoiListState.selected_roi.id) {
                            RoiListState.selected_roi = {
                                id: 0,
                                name: "",
                                display_color: #000000,
                                display_name: "",
                                class_names: [],
                                class_colors: [],
                                class_ids: [],
                                label_name: "",
                                label_id: 0,
                                intensities: [],
                                intensity_avgs: [],
                            };
                            RoiListState.roi_selected(-1);
                        } else {
                            RoiListState.selected_roi = data;
                            RoiListState.roi_selected(data.id);
                        }
                    }
                }
            }

            // Scanning overlay
            if RoiListState.is_scanning: Rectangle {
                background: Theme.overlay-scrim;
                Spinner {
                    indeterminate: true;
                }

                TouchArea { }
            }
        }

        // ----- SELECTED ROI DETAIL -----
        if RoiListState.selected_roi.id != 0: Rectangle {
            background: Theme.raised;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border-soft;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                // Label name + label count chip + display name
                HorizontalLayout {
                    alignment: space-between;
                    spacing: 6px;
                    Text {
                        text: RoiListState.selected_roi.label_name;
                        font-size: 12px;
                        font-weight: 500;
                        color: Theme.text;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    // Label count chip
                    if RoiListState.selected_roi.label_count > 0: VerticalLayout {
                        alignment: center;
                        Rectangle {
                            height: 16px;
                            min-width: 24px;
                            border-radius: 3px;
                            background: rgba(77, 141, 255, 0.10);
                            border-width: 1px;
                            border-color: rgba(77, 141, 255, 0.20);
                            HorizontalLayout {
                                padding-left: 5px;
                                padding-right: 5px;
                                Text {
                                    text: RoiListState.selected_roi.label_count + "×";
                                    font-size: 10px;
                                    font-family: Theme.font-mono;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    // Display name
                    if RoiListState.selected_roi.display_name != "": Text {
                        text: RoiListState.selected_roi.display_name;
                        font-size: 10px;
                        font-family: Theme.font-mono;
                        color: Theme.text-mute;
                        vertical-alignment: center;
                        height: 10px;
                    }
                }

                // Classes list (only when classes are defined)
                if RoiListState.selected_roi.class_names.length > 0: Rectangle {
                    background: rgba(255, 255, 255, 0.03);
                    border-radius: 4px;

                    VerticalLayout {
                        spacing: 2px;
                        padding: 4px;

                        for class_name[index] in RoiListState.selected_roi.class_names: HorizontalLayout {
                            spacing: 6px;
                            height: 20px;

                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 2px;
                                    background: RoiListState.selected_roi.class_colors[index];
                                }
                            }

                            Text {
                                text: class_name;
                                font-size: 11px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }

                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 16px;
                                    height: 16px;
                                    border-radius: 3px;
                                    background: rm_ta.has-hover ? rgba(248, 113, 113, 0.15) : transparent;
                                    animate background { duration: 80ms; }

                                    Text {
                                        text: "×";
                                        font-size: 11px;
                                        color: Theme.text-faint;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    rm_ta := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            RoiListState.roi_remove_class(
                                                RoiListState.selected_roi.id,
                                                RoiListState.selected_roi.class_ids[index]);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Divider
                Rectangle {
                    height: 1px;
                    background: Theme.border;
                    opacity: 0.4;
                }

                // Metrics – vertical stack
                VerticalLayout {
                    spacing: 4px;

                    // AREA
                    HorizontalLayout {
                        alignment: space-between;
                        height: 18px;
                        Text {
                            text: "AREA";
                            font-size: 9px;
                            font-family: Theme.font-mono;
                            color: Theme.text-faint;
                            vertical-alignment: center;
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 1px;
                            Text {
                                text: RoiListState.selected_roi.area > 0 ? RoiListState.selected_roi.area + " px²" : "–";
                                font-size: 11px;
                                font-family: Theme.font-mono;
                                color: Theme.text-mute;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                            if RoiListState.selected_roi.area_nm2 != "": Text {
                                text: RoiListState.selected_roi.area_nm2 + " nm²";
                                font-size: 9px;
                                font-family: Theme.font-mono;
                                color: Theme.text-faint;
                                vertical-alignment: center;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    // CIRCULARITY
                    HorizontalLayout {
                        alignment: space-between;
                        height: 18px;
                        Text {
                            text: "CIRCULARITY";
                            font-size: 9px;
                            font-family: Theme.font-mono;
                            color: Theme.text-faint;
                            vertical-alignment: center;
                        }

                        Text {
                            text: RoiListState.selected_roi.circularity != "" ? RoiListState.selected_roi.circularity : "–";
                            font-size: 11px;
                            font-family: Theme.font-mono;
                            color: Theme.text-mute;
                            vertical-alignment: center;
                        }
                    }

                    // INTENSITY – section header
                    HorizontalLayout {
                        alignment: space-between;
                        height: 18px;
                        Text {
                            text: "INTENSITY";
                            font-size: 9px;
                            font-family: Theme.font-mono;
                            color: Theme.text-faint;
                            vertical-alignment: center;
                        }
                    }

                    // Per-channel intensity rows
                    if RoiListState.selected_roi.intensities.length > 0: VerticalLayout {
                        spacing: 2px;
                        for intensity_val[i] in RoiListState.selected_roi.intensities: HorizontalLayout {
                            alignment: space-between;
                            padding-left: 6px;
                            height: 18px;

                            HorizontalLayout {
                                spacing: 5px;
                                alignment: start;

                                // Channel color swatch (if channel info available)
                                if ChannelState.channels.length > i: VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 7px;
                                        height: 7px;
                                        border-radius: 2px;
                                        background: ChannelState.channels[i].color;
                                    }
                                }

                                Text {
                                    text: ChannelState.channels.length > i ? ChannelState.channels[i].name : "Ch " + (i + 1);
                                    font-size: 10px;
                                    color: Theme.text-dim;
                                    vertical-alignment: center;
                                }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                alignment: end;

                                // Sum
                                HorizontalLayout {
                                    spacing: 2px;
                                    Text {
                                        text: "Σ";
                                        font-size: 9px;
                                        color: Theme.text-faint;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: intensity_val != "" ? intensity_val : "–";
                                        font-size: 10px;
                                        font-family: Theme.font-mono;
                                        color: Theme.text-mute;
                                        vertical-alignment: center;
                                    }
                                }

                                // Avg
                                HorizontalLayout {
                                    spacing: 2px;
                                    Text {
                                        text: "μ";
                                        font-size: 9px;
                                        color: Theme.text-faint;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: RoiListState.selected_roi.intensity_avgs.length > i
                                            ? (RoiListState.selected_roi.intensity_avgs[i] != ""
                                                ? RoiListState.selected_roi.intensity_avgs[i]
                                                : "–")
                                            : "–";
                                        font-size: 10px;
                                        font-family: Theme.font-mono;
                                        color: Theme.text-mute;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // Fallback when no intensities computed yet
                    if RoiListState.selected_roi.intensities.length == 0: HorizontalLayout {
                        alignment: space-between;
                        padding-left: 6px;
                        height: 18px;
                        Text {
                            text: "–";
                            font-size: 11px;
                            font-family: Theme.font-mono;
                            color: Theme.text-mute;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ----- FOOTER TOOLBAR -----
        Rectangle {
            height: 38px;
            background: Theme.bg;
            border-width: 1px;
            border-color: Theme.border-soft;
            border-radius: Theme.radius-md;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 2px;
                alignment: stretch;

                VerticalLayout {
                    alignment: center;
                    ActionButton {
                        icon: @image-url("../icons/regular-white/copy-simple.svg");
                        enabled: RoiListState.selected_roi.id != 0;
                        clicked => {
                            RoiListState.roi_copy(RoiListState.selected_roi.id);
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    ActionButton {
                        icon: @image-url("../icons/regular-white/trash-simple.svg");
                        enabled: RoiListState.selected_roi.id != 0;
                        clicked => {
                            GlobalAppState.active_dialog = DialogType.roi_confirm_delete;
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    ActionButton {
                        icon: @image-url("../icons/regular-white/pencil-simple.svg");
                        enabled: RoiListState.selected_roi.id != 0;
                        clicked => {
                            RoiListState.roi_edit(RoiListState.selected_roi.id);
                        }
                    }
                }

                // Divider
                VerticalLayout {
                    alignment: center;
                    padding-left: 4px;
                    padding-right: 4px;
                    Rectangle {
                        width: 1px;
                        height: 16px;
                        background: Theme.border;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                // Add class – primary action
                VerticalLayout {
                    alignment: center;
                    Button {
                        text: "+ Class";
                        primary: true;
                        enabled: RoiListState.selected_roi.id != 0;
                        clicked => {
                            RoiListState.roi_add_class(RoiListState.selected_roi.id);
                        }
                    }
                }
            }
        }
    }
}
