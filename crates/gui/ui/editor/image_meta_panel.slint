import {
    LineEdit,
    Button,
    VerticalBox,
    Palette,
} from "std-widgets.slint";
import { Theme } from "../style.slint";

// ----------------------------------------------------------
export global ImageMetaData {
    in property <string> image_name: "No image opened";
    in property <string> dimensions_str: "";
    in property <int> nr_c_stacks: 0;
    in property <int> nr_z_stacks: 0;
    in property <int> nr_t_stacks: 0;

    in property <string> storage_size: "";
    in property <string> magnification: "";
    in property <string> size: "";
    in property <string> pixel_size_str: "200, 200, 200 nm";

    in property <float> pixel_size_x: 0.0;
    in property <float> pixel_size_y: 0.0;
    in property <float> pixel_size_z: 0.0;

    in property <string> pixel_type: "";
    in property <int> nr_series: 0;
    in property <string> nr_series_str: "";
    in-out property <int> selected_series: 0;

    callback reset_pixel_sizes();
    callback pixel_size_changed(float, float, float);
    callback series_selected(int);
}

// ----------------------------------------------------------
// Key/value row - used inside every section.
component MetaRow inherits Rectangle {
    in property <string> key;
    in property <string> value;
    in property <bool> mute: false;
    in property <bool> last: false;

    height: 26px;

    HorizontalLayout {
        alignment: space-between;
        spacing: 12px;
        padding-top: 4px;
        padding-bottom: 4px;

        Text {
            text: root.key;
            font-size: 11.5px;
            color: Theme.text-dim;
            vertical-alignment: center;
        }

        Text {
            text: root.value == "" ? "-" : root.value;
            font-size: 11.5px;
            font-family: Theme.font-mono;
            color: root.mute || root.value == "" ? Theme.text-mute : Theme.text;
            vertical-alignment: center;
            horizontal-alignment: right;
            overflow: elide;
        }
    }

    // Hairline divider
    if !root.last: Rectangle {
        x: 0px;
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border-soft;
    }
}

// Section wrapper - uppercase micro-label + optional right-aligned action slot.
export component MetaGroup inherits VerticalLayout {
    in property <string> title;
    spacing: 0px;
    padding-bottom: 8px;
}

// ----------------------------------------------------------
export component ImageMetaPanel inherits Rectangle {
    property <bool> editing_px: false;

    VerticalBox {
        alignment: start;
        spacing: 12px;
        padding: Theme.panel-content-padding;

        // ----- HEADER -----
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "Image Meta";
                font-size: 14px;
                font-weight: 600;
                color: Theme.text;
                vertical-alignment: center;
            }

            Text {
                text: ImageMetaData.nr_series <= 1 ? "1 series" : ImageMetaData.nr_series + " series";
                font-size: 11px;
                font-family: Theme.font-mono;
                color: Theme.text-mute;
                vertical-alignment: center;
            }
        }

        // ----- FILE CARD -----
        Rectangle {
            background: Theme.raised;
            border-width: 1px;
            border-color: Theme.border-soft;
            border-radius: Theme.radius-lg;
            height: ImageMetaData.nr_series > 1 ? 96px : 56px;

            VerticalLayout {
                padding: 10px;
                spacing: 10px;

                // Filename row: icon + name + format chip
                HorizontalLayout {
                    spacing: 9px;
                    alignment: start;

                    // Icon plate (gradient backplate so it stands out)
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 6px;
                        background: @linear-gradient(135deg, Theme.accent-dim 0%, #2A2D33 100%);
                        Image {
                            source: @image-url("../icons/regular-white/aperture.svg");
                            width: 15px;
                            height: 15px;
                            colorize: Theme.accent;
                        }
                    }

                    VerticalLayout {
                        spacing: 1px;
                        horizontal-stretch: 1;
                        alignment: center;

                        Text {
                            text: ImageMetaData.image_name;
                            font-size: 13px;
                            font-weight: 500;
                            color: Theme.text;
                            overflow: elide;
                        }

                        Text {
                            text: (ImageMetaData.pixel_type == "" ? "-" : ImageMetaData.pixel_type) + "  ·  " + (ImageMetaData.storage_size == "" ? "-" : ImageMetaData.storage_size);
                            font-size: 10.5px;
                            font-family: Theme.font-mono;
                            color: Theme.text-mute;
                            overflow: elide;
                        }
                    }
                }

                // Series indicator - only if more than one series
                if ImageMetaData.nr_series > 1: Rectangle {
                    height: 32px;
                    background: Theme.bg;
                    border-width: 1px;
                    border-color: Theme.border-soft;
                    border-radius: Theme.radius-sm;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 4px;
                        spacing: 6px;
                        alignment: stretch;

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Series " + ImageMetaData.selected_series + " of " + (ImageMetaData.nr_series - 1);
                                font-size: 11px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: ImageMetaData.size;
                                font-size: 11px;
                                font-family: Theme.font-mono;
                                color: Theme.text;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }
                        // Prev / next series buttons
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                border-radius: 4px;
                                background: prev_ta.has-hover ? Theme.raised : transparent;
                                animate background { duration: 100ms; }
                                Image {
                                    source: @image-url("../icons/regular-white/caret-left.svg");
                                    width: 11px;
                                    height: 11px;
                                    colorize: Theme.text-dim;
                                }

                                prev_ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if (ImageMetaData.selected_series > 0) {
                                            ImageMetaData.selected_series -= 1;
                                            ImageMetaData.series_selected(ImageMetaData.selected_series);
                                        }
                                    }
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                border-radius: 4px;
                                background: next_ta.has-hover ? Theme.raised : transparent;
                                animate background { duration: 100ms; }
                                Image {
                                    source: @image-url("../icons/regular-white/caret-right.svg");
                                    width: 11px;
                                    height: 11px;
                                    colorize: Theme.text-dim;
                                }

                                next_ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if (ImageMetaData.selected_series < ImageMetaData.nr_series - 1) {
                                            ImageMetaData.selected_series += 1;
                                            ImageMetaData.series_selected(ImageMetaData.selected_series);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ----- ACQUISITION -----
        VerticalLayout {
            spacing: 0px;
            Text {
                text: "ACQUISITION";
                font-size: 9.5px;
                font-weight: 600;
                letter-spacing: 0.8px;
                color: Theme.text-mute;
                vertical-alignment: center;
                height: 22px;
            }

            MetaRow {
                key: "Magnification";
                value: ImageMetaData.magnification;
            }

            MetaRow {
                key: "Channels · Z · T";
                value: ImageMetaData.dimensions_str;
            }

            MetaRow {
                key: "Bit depth";
                value: ImageMetaData.pixel_type;
                last: true;
            }
        }

        // ----- DIMENSIONS -----
        VerticalLayout {
            spacing: 0px;
            Text {
                text: "DIMENSIONS";
                font-size: 9.5px;
                font-weight: 600;
                letter-spacing: 0.8px;
                color: Theme.text-mute;
                vertical-alignment: center;
                height: 22px;
            }

            MetaRow {
                key: "Width × Height";
                value: ImageMetaData.size;
            }

            MetaRow {
                key: "Storage size";
                value: ImageMetaData.storage_size;
                last: true;
            }
        }

        // ----- CALIBRATION (with inline edit mode) -----
        VerticalLayout {
            spacing: 0px;

            // Section head with action buttons
            HorizontalLayout {
                alignment: space-between;
                height: 26px;
                Text {
                    text: "CALIBRATION";
                    font-size: 9.5px;
                    font-weight: 600;
                    letter-spacing: 0.8px;
                    color: Theme.text-mute;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 4px;
                    alignment: end;

                    if root.editing_px: Rectangle {
                        height: 22px;
                        min-width: 44px;
                        border-radius: 4px;
                        background: reset_ta.has-hover ? Theme.raised : transparent;
                        border-width: 1px;
                        border-color: Theme.border;
                        animate background { duration: 100ms; }
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            Text {
                                text: "Reset";
                                font-size: 10.5px;
                                color: Theme.text-dim;
                                vertical-alignment: center;
                            }
                        }

                        reset_ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.editing_px = false;
                                ImageMetaData.reset_pixel_sizes();
                            }
                        }
                    }

                    Rectangle {
                        height: 22px;
                        min-width: 44px;
                        border-radius: 4px;
                        background: edit_ta.has-hover ? Theme.raised : transparent;
                        animate background { duration: 100ms; }
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 8px;
                            spacing: 4px;
                            alignment: center;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: root.editing_px ? @image-url("../icons/regular-white/check.svg") : @image-url("../icons/regular-white/pencil-simple.svg");
                                    width: 10px;
                                    height: 10px;
                                    colorize: Theme.accent;
                                }
                            }

                            Text {
                                text: root.editing_px ? "Done" : "Edit";
                                font-size: 10.5px;
                                color: Theme.accent;
                                vertical-alignment: center;
                            }
                        }

                        edit_ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.editing_px = !root.editing_px;
                                if (!root.editing_px) {
                                    ImageMetaData.pixel_size_changed(
                                        ImageMetaData.pixel_size_x,
                                        ImageMetaData.pixel_size_y,
                                        ImageMetaData.pixel_size_z);
                                }
                            }
                        }
                    }
                }
            }

            // Read mode - three mono rows
            if !root.editing_px: VerticalLayout {
                spacing: 0px;
                MetaRow {
                    key: "Pixel X";
                    value: ImageMetaData.pixel_size_x + " nm";
                }

                MetaRow {
                    key: "Pixel Y";
                    value: ImageMetaData.pixel_size_y + " nm";
                }

                MetaRow {
                    key: "Pixel Z";
                    value: ImageMetaData.pixel_size_z + " nm";
                    mute: ImageMetaData.pixel_size_z == 0.0;
                    last: true;
                }
            }

            // Edit mode - three labeled LineEdits in a row
            if root.editing_px: Rectangle {
                background: Theme.raised;
                border-width: 1px;
                border-color: Theme.border-soft;
                border-radius: Theme.radius-md;
                height: 64px;

                HorizontalLayout {
                    padding: 8px;
                    spacing: 6px;
                    alignment: stretch;

                    for axis[i] in [
                        { label: "X", val: ImageMetaData.pixel_size_x },
                        { label: "Y", val: ImageMetaData.pixel_size_y },
                        { label: "Z", val: ImageMetaData.pixel_size_z },
                    ]: VerticalLayout {
                        spacing: 3px;
                        horizontal-stretch: 1;

                        Text {
                            text: axis.label + "  (nm)";
                            font-size: 9.5px;
                            letter-spacing: 0.5px;
                            color: Theme.text-mute;
                        }

                        LineEdit {
                            height: 28px;
                            text: axis.val;
                            edited(t) => {
                                if (t.is-float()) {
                                    if (i == 0) {
                                        ImageMetaData.pixel_size_x = t.to-float();
                                    }
                                    if (i == 1) {
                                        ImageMetaData.pixel_size_y = t.to-float();
                                    }
                                    if (i == 2) {
                                        ImageMetaData.pixel_size_z = t.to-float();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
