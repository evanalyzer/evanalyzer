import { Theme } from "../style.slint";

component LiverCell inherits Rectangle {
    in property <color> ink;
    width: 18px;
    height: 26px;
    border-radius: 6px;
    background: root.ink;

    Rectangle {
        width: 10px;
        height: 10px;
        x: 4px;
        y: 8px;
        border-radius: 5px;
        background: #ffffff;

        Rectangle {
            width: 4px;
            height: 4px;
            x: 3px;
            y: 3px;
            border-radius: 2px;
            background: root.ink;
        }
    }
}

component NeuronCell inherits Rectangle {
    in property <color> ink;
    width: 6px;
    height: 36px;
    border-radius: 3px;
    background: root.ink;

    Rectangle {
        width: 16px;
        height: 16px;
        x: -5px;
        y: 0px;
        border-radius: 8px;
        background: root.ink;

        Rectangle {
            width: 6px;
            height: 6px;
            x: 5px;
            y: 5px;
            border-radius: 3px;
            background: #ffffff;

            Rectangle {
                width: 2px;
                height: 2px;
                x: 2px;
                y: 2px;
                border-radius: 1px;
                background: root.ink;
            }
        }

        Rectangle {
            width: 5px;
            height: 2px;
            x: -3px;
            y: 4px;
            background: root.ink;
        }

        Rectangle {
            width: 6px;
            height: 2px;
            x: 14px;
            y: 8px;
            background: root.ink;
        }

        Rectangle {
            width: 2px;
            height: 4px;
            x: 4px;
            y: -2px;
            background: root.ink;
        }
    }

    Rectangle {
        width: 10px;
        height: 8px;
        x: -2px;
        y: 18px;
        border-radius: 3px;
        background: root.ink;
    }

    Rectangle {
        width: 10px;
        height: 8px;
        x: -2px;
        y: 28px;
        border-radius: 3px;
        background: root.ink;
    }
}

component CancerCell inherits Rectangle {
    // Irregular green cancer cell - enlarged nucleus, pseudopods
    width: 22px;
    height: 22px;
    border-radius: 9px;
    background: #000;

    // Top pseudopod (irregular membrane protrusion)
    Rectangle {
        width: 8px;
        height: 5px;
        x: 4px;
        y: -3px;
        border-radius: 3px;
        background: #000;
    }

    // Right pseudopod
    Rectangle {
        width: 5px;
        height: 7px;
        x: 19px;
        y: 6px;
        border-radius: 2px;
        background: #000;
    }

    // Enlarged off-centre nucleus (major cancer hallmark)
    Rectangle {
        width: 14px;
        height: 13px;
        x: 3px;
        y: 4px;
        border-radius: 6px;
        background: #000;

        // Prominent nucleolus
        Rectangle {
            width: 5px;
            height: 5px;
            x: 4px;
            y: 4px;
            border-radius: 3px;
            background: #fff;
        }

        // Second nucleolus (cancer cells often have multiple)
        Rectangle {
            width: 3px;
            height: 3px;
            x: 1px;
            y: 1px;
            border-radius: 2px;
            background: #fff;
        }
    }
}

component MuscleCell inherits Rectangle {
    // Striated muscle fibre - banded body, two staggered peripheral nuclei
    in property <color> ink;
    width: 14px;
    height: 32px;
    border-radius: 3px;
    background: root.ink;

    // Striations (Z-lines / I-band pattern)
    Rectangle {
        width: 10px;
        height: 1px;
        x: 2px;
        y: 5px;
        background: #ffffff;
        opacity: 0.45;
    }

    Rectangle {
        width: 10px;
        height: 1px;
        x: 2px;
        y: 10px;
        background: #ffffff;
        opacity: 0.45;
    }

    Rectangle {
        width: 10px;
        height: 1px;
        x: 2px;
        y: 15px;
        background: #ffffff;
        opacity: 0.45;
    }

    Rectangle {
        width: 10px;
        height: 1px;
        x: 2px;
        y: 20px;
        background: #ffffff;
        opacity: 0.45;
    }

    Rectangle {
        width: 10px;
        height: 1px;
        x: 2px;
        y: 25px;
        background: #ffffff;
        opacity: 0.45;
    }

    // Peripheral nucleus 1 (top-left)
    Rectangle {
        width: 5px;
        height: 7px;
        x: 1px;
        y: 7px;
        border-radius: 2px;
        background: #ffffff;
    }

    // Peripheral nucleus 2 (bottom-right, staggered)
    Rectangle {
        width: 5px;
        height: 7px;
        x: 8px;
        y: 18px;
        border-radius: 2px;
        background: #ffffff;
    }
}

component Bump-Small inherits Rectangle {
    in property <length> x-in;
    in property <length> y-in;
    in property <color> bg;
    in property <color> ink;

    Rectangle {
        x: root.x-in;
        y: root.y-in - 4px;
        width: 25px;
        height: 6px;
        background: root.bg;
    }

    Rectangle {
        x: root.x-in;
        y: root.y-in - 10px;
        width: 25px;
        height: 10px;

        for height-value[index] in [
            0px,
            1px,
            1px,
            1px,
            1px,
            2px,
            2px,
            2px,
            2px,
            2px,
            3px,
            3px,
            3px,
            3px,
            3px,
            3px,
            2px,
            2px,
            2px,
            2px,
            1px,
            1px,
            1px,
            0px,
            0px
        ]: Rectangle {
            x: index * 1px;
            y: parent.height - height-value;
            width: 1px;
            height: 1px;
            background: root.ink;
        }
    }
}

component Bump-Double inherits Rectangle {
    in property <length> x-in;
    in property <length> y-in;
    in property <color> bg;
    in property <color> ink;

    Rectangle {
        x: root.x-in;
        y: root.y-in - 4px;
        width: 30px;
        height: 6px;
        background: root.bg;
    }

    Rectangle {
        x: root.x-in;
        y: root.y-in - 10px;
        width: 30px;
        height: 10px;

        for height-value[index] in [
            0px,
            1px,
            2px,
            3px,
            2px,
            1px,
            0px,
            0px,
            0px,
            0px,
            0px,
            0px,
            0px,
            1px,
            2px,
            3px,
            3px,
            2px,
            1px,
            0px,
            0px,
            0px,
            0px,
            1px,
            2px,
            2px,
            1px,
            0px,
            0px,
            0px
        ]: Rectangle {
            x: index * 1px;
            y: parent.height - height-value;
            width: 1px;
            height: 1px;
            background: root.ink;
        }
    }
}

component Bump-Jagged inherits Rectangle {
    in property <length> x-in;
    in property <length> y-in;
    in property <color> bg;
    in property <color> ink;

    Rectangle {
        x: root.x-in;
        y: root.y-in - 4px;
        width: 18px;
        height: 6px;
        background: root.bg;
    }

    Rectangle {
        x: root.x-in;
        y: root.y-in - 10px;
        width: 18px;
        height: 10px;

        for height-value[index] in [
            0px,
            1px,
            1px,
            3px,
            3px,
            5px,
            5px,
            4px,
            4px,
            6px,
            6px,
            3px,
            3px,
            2px,
            2px,
            1px,
            1px,
            0px
        ]: Rectangle {
            x: index * 1px;
            y: parent.height - height-value;
            width: 1px;
            height: 1px;
            background: root.ink;
        }
    }
}

component ExtracellularVesicle inherits Rectangle {
    in property <length> ball-size;
    in property <int> step;
    in property <color> background-inner;

    width: ball-size;
    height: ball-size;
    border-radius: ball-size / 2;
    border-width: 2.5px;

    Rectangle {
        width: 4px;
        height: 4px;
        border-radius: 2px;
        background: root.background-inner;
        x: root.step == 0 ? 11px : root.step == 1 ? 10px : root.step == 2 ? 8px : root.step == 3 ? 6px : root.step == 4 ? 5px : root.step == 5 ? 6px : root.step == 6 ? 8px : 10px;
        y: root.step == 0 ? 8px : root.step == 1 ? 10px : root.step == 2 ? 11px : root.step == 3 ? 10px : root.step == 4 ? 8px : root.step == 5 ? 6px : root.step == 6 ? 5px : 6px;
    }

    Rectangle {
        width: 3px;
        height: 3px;
        border-radius: 2px;
        background: root.background-inner;
        x: root.step == 0 ? 9px : root.step == 1 ? 5px : root.step == 2 ? 4px : root.step == 3 ? 5px : root.step == 4 ? 9px : root.step == 5 ? 12px : root.step == 6 ? 14px : 12px;
        y: root.step == 0 ? 14px : root.step == 1 ? 12px : root.step == 2 ? 9px : root.step == 3 ? 5px : root.step == 4 ? 4px : root.step == 5 ? 5px : root.step == 6 ? 9px : 12px;
    }
}

export component BioRunner inherits Rectangle {
    private property <color> ink: Theme.game-ink;
    private property <color> paper: Theme.game-paper;

    background: paper;
    border-radius: 6px;
    clip: true;
    height: 96px;

    private property <length> ground-y:   68px;
    private property <length> ball-size:  20px;
    private property <length> ball-x:     52px;

    private property <bool> game-over: false;
    private property <int> cancer-score: 0;

    in property <bool> paused: false;

    private property <int> step: 0;
    Timer {
        interval: 130ms;
        running: true;
        triggered => {
            if (!game-over && !paused) {
                step = step >= 7 ? 0 : step + 1;
            }
        }
    }

    private property <float> title-opacity: 1.0;
    Timer {
        interval: 3500ms;
        running: root.title-opacity > 0.5;
        triggered => {
            title-opacity = 0.0;
        }
    }

    private property <float> banner-opacity: 0.0;
    Timer {
        interval: 1800ms;
        running: root.banner-opacity > 0.5;
        triggered => {
            banner-opacity = 0.0;
        }
    }

    // -- Clean, Robust Jump Logic Framework ------------------------
    private property <length> ball-y-offset: 0px;
    private property <int> jump-frame-counter: -1;

    // Fixed Obstacle and Terrain positions
    private property <length> obs1-x: 460px;
    private property <length> obs2-x: 730px;

    private property <int> obs1-type: 1;
    private property <int> obs2-type: 2;
    private property <int> pseudo-seed: 23;

    private property <int> b1-type: 0;
    private property <int> b2-type: 1;
    private property <int> b5-type: 2;

    private property <length> g1-x:  35px;
    private property <length> g2-x:  82px;
    private property <length> g3-x: 128px;
    private property <length> g4-x: 178px;
    private property <length> g5-x: 224px;
    private property <length> g6-x: 272px;
    private property <length> g7-x: 322px;
    private property <length> g8-x: 372px;

    private property <length> b1-x:  70px;
    private property <length> b2-x: 150px;
    private property <length> b5-x: 360px;
    private property <length> move-speed: 9px;
    private property <bool> auto-jump: true;

    Timer {
        interval: 32ms;
        running: true;
        triggered => {
            if (!game-over && !paused) {
                pseudo-seed = pseudo-seed > 100 ? 11 : pseudo-seed + 7;
            // --- Jump Physics Routine (32 ms / ~31 Hz tick) ---
            if (jump-frame-counter >= 0) {
                    jump-frame-counter += 1;
                    if (jump-frame-counter <= 3) {
                        ball-y-offset += 14px;
                    }
                    if (jump-frame-counter > 10 && jump-frame-counter <= 13) {
                        ball-y-offset -= 14px;
                    }
                    if (jump-frame-counter > 13) {
                        ball-y-offset = 0px;
                        jump-frame-counter = -1;
                    }
                }
                obs1-x -= move-speed;
                obs2-x -= move-speed;

            // Obstacle wrap - penalise missed cancer cells
            if (obs1-x < -40px) {
                    if (obs1-type == 3) {
                        cancer-score -= 1;
                        if (cancer-score < 0) {
                            game-over = true;
                        }
                    }
                    obs1-x = obs2-x + 220px + (pseudo-seed * 1px);
                    obs1-type = Math.mod(pseudo-seed, 5);
                }
                if (obs2-x < -40px) {
                    if (obs2-type == 3) {
                        cancer-score -= 1;
                        if (cancer-score < 0) {
                            game-over = true;
                        }
                    }
                    obs2-x = obs1-x + 240px + (Math.mod(pseudo-seed * 3, 35) * 1px);
                    obs2-type = Math.mod(pseudo-seed + 1, 5);
                }

            // Auto-jump: trigger when a normal obstacle (liver/neuron/muscle) is ~80px ahead
            if (auto-jump && jump-frame-counter == -1) {
                    if ((obs1-type == 1 || obs1-type == 2 || obs1-type == 4) && obs1-x > root.ball-x && obs1-x < root.ball-x + 80px) {
                        jump-frame-counter = 0;
                    }
                    if ((obs2-type == 1 || obs2-type == 2 || obs2-type == 4) && obs2-x > root.ball-x && obs2-x < root.ball-x + 80px) {
                        jump-frame-counter = 0;
                    }
                }

            // Cancer cell: destroy on contact → increment score
            if (obs1-type == 3 && jump-frame-counter == -1 && obs1-x > root.ball-x - 22px && obs1-x < root.ball-x + root.ball-size) {
                    obs1-type = 0;
                    cancer-score += 1;
                }
                if (obs2-type == 3 && jump-frame-counter == -1 && obs2-x > root.ball-x - 22px && obs2-x < root.ball-x + root.ball-size) {
                    obs2-type = 0;
                    cancer-score += 1;
                }

            // Game over: normal cell reaches vesicle while on the ground
            if (jump-frame-counter == -1) {
                    if ((obs1-type == 1 || obs1-type == 2 || obs1-type == 4) && obs1-x > root.ball-x - 18px && obs1-x < root.ball-x + root.ball-size) {
                        game-over = true;
                    }
                    if ((obs2-type == 1 || obs2-type == 2 || obs2-type == 4) && obs2-x > root.ball-x - 18px && obs2-x < root.ball-x + root.ball-size) {
                        game-over = true;
                    }
                }
                g1-x -= move-speed;
                if (g1-x < -10px) {
                    g1-x = 450px;
                }
                g2-x -= move-speed;
                if (g2-x < -10px) {
                    g2-x = 440px;
                }
                g3-x -= move-speed;
                if (g3-x < -10px) {
                    g3-x = 460px;
                }
                g4-x -= move-speed;
                if (g4-x < -10px) {
                    g4-x = 445px;
                }
                g5-x -= move-speed;
                if (g5-x < -10px) {
                    g5-x = 470px;
                }
                g6-x -= move-speed;
                if (g6-x < -10px) {
                    g6-x = 455px;
                }
                g7-x -= move-speed;
                if (g7-x < -10px) {
                    g7-x = 480px;
                }
                g8-x -= move-speed;
                if (g8-x < -10px) {
                    g8-x = 435px;
                }
                b1-x -= move-speed;
                if (b1-x < -35px) {
                    b1-x = 440px;
                    b1-type = Math.mod(pseudo-seed, 3);
                }
                b2-x -= move-speed;
                if (b2-x < -35px) {
                    b2-x = 465px;
                    b2-type = Math.mod(pseudo-seed + 2, 3);
                }
                b5-x -= move-speed;
                if (b5-x < -35px) {
                    b5-x = 490px;
                    b5-type = Math.mod(pseudo-seed + 4, 3);
                }
            } // end if (!game-over)
        }
    }

    // Background title
    Text {
        text: "Hit the Cancer";
        font-family: "DejaVu Sans Mono";
        font-size: 22px;
        font-weight: 800;
        color: Theme.game-title;
        x: 0px;
        y: 6px;
        width: parent.width;
        horizontal-alignment: center;
        opacity: root.title-opacity;
        animate opacity {
            duration: 4500ms;
            easing: ease-in;
        }
    }

    Text {
        text: "- press space to play -";
        font-family: "DejaVu Sans Mono";
        font-size: 10px;
        font-weight: 400;
        color: Theme.game-subtitle;
        x: 0px;
        y: 33px;
        width: parent.width;
        horizontal-alignment: center;
        opacity: root.title-opacity;
        animate opacity {
            duration: 4500ms;
            easing: ease-in;
        }
    }

    // "It's your turn" takeover banner
    Text {
        text: "It's your turn!";
        font-family: "DejaVu Sans Mono";
        font-size: 14px;
        font-weight: 700;
        color: root.ink;
        x: 0px;
        y: 28px;
        width: parent.width;
        horizontal-alignment: center;
        opacity: root.banner-opacity;
        animate opacity {
            duration: 700ms;
            easing: ease-in;
        }
    }

    // Baseline Ground Axis
    Rectangle {
        y: root.ground-y;
        width: parent.width;
        height: 1px;
        background: root.ink;
    }

    // Terrain Components
    Bump-Small {
        x-in: root.b1-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b1-type == 0;
    }

    Bump-Double {
        x-in: root.b1-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b1-type == 1;
    }

    Bump-Jagged {
        x-in: root.b1-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b1-type == 2;
    }

    Bump-Small {
        x-in: root.b2-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b2-type == 0;
    }

    Bump-Double {
        x-in: root.b2-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b2-type == 1;
    }

    Bump-Jagged {
        x-in: root.b2-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b2-type == 2;
    }

    Bump-Small {
        x-in: root.b5-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b5-type == 0;
    }

    Bump-Double {
        x-in: root.b5-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b5-type == 1;
    }

    Bump-Jagged {
        x-in: root.b5-x;
        y-in: root.ground-y;
        bg: root.paper;
        ink: root.ink;
        visible: root.b5-type == 2;
    }

    // Pebbles
    Rectangle {
        width: 3px;
        height: 1px;
        x: root.g1-x;
        y: root.ground-y + 5px;
        background: root.ink;
    }

    Rectangle {
        width: 5px;
        height: 1px;
        x: root.g2-x;
        y: root.ground-y + 9px;
        background: root.ink;
    }

    Rectangle {
        width: 2px;
        height: 1px;
        x: root.g3-x;
        y: root.ground-y + 5px;
        background: root.ink;
    }

    Rectangle {
        width: 4px;
        height: 2px;
        x: root.g4-x;
        y: root.ground-y + 7px;
        background: root.ink;
    }

    Rectangle {
        width: 3px;
        height: 1px;
        x: root.g5-x;
        y: root.ground-y + 11px;
        background: root.ink;
    }

    Rectangle {
        width: 2px;
        height: 1px;
        x: root.g6-x;
        y: root.ground-y + 6px;
        background: root.ink;
    }

    Rectangle {
        width: 4px;
        height: 1px;
        x: root.g7-x;
        y: root.ground-y + 8px;
        background: root.ink;
    }

    Rectangle {
        width: 3px;
        height: 2px;
        x: root.g8-x;
        y: root.ground-y + 5px;
        background: root.ink;
    }

    // Player (Vesicle)
    ExtracellularVesicle {
        ball-size: ball-size;
        x: root.ball-x;
        y: root.ground-y - root.ball-size - root.ball-y-offset;
        step: root.step;
        background-inner: root.ink;
        border-color: root.ink;
    }

    // Obstacles
    LiverCell {
        ink: root.ink;
        x: root.obs1-x;
        y: root.ground-y - 26px;
        visible: root.obs1-type == 1;
    }

    NeuronCell {
        ink: root.ink;
        x: root.obs1-x;
        y: root.ground-y - 36px;
        visible: root.obs1-type == 2;
    }

    CancerCell {
        x: root.obs1-x;
        y: root.ground-y - 22px;
        visible: root.obs1-type == 3;
    }

    MuscleCell {
        ink: root.ink;
        x: root.obs1-x;
        y: root.ground-y - 32px;
        visible: root.obs1-type == 4;
    }

    LiverCell {
        ink: root.ink;
        x: root.obs2-x;
        y: root.ground-y - 26px;
        visible: root.obs2-type == 1;
    }

    NeuronCell {
        ink: root.ink;
        x: root.obs2-x;
        y: root.ground-y - 36px;
        visible: root.obs2-type == 2;
    }

    CancerCell {
        x: root.obs2-x;
        y: root.ground-y - 22px;
        visible: root.obs2-type == 3;
    }

    MuscleCell {
        ink: root.ink;
        x: root.obs2-x;
        y: root.ground-y - 32px;
        visible: root.obs2-type == 4;
    }

    // Cancer cell score (top-right, always visible)
    Text {
        text: "🦠 " + root.cancer-score;
        font-size: 11px;
        font-weight: 700;
        color: Theme.game-green;
        x: parent.width - 54px;
        y: 4px;
    }

    // Game-over overlay (visual only - input handled by the FocusScope below)
    Rectangle {
        visible: root.game-over;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: Theme.game-paper.with-alpha(0.88);

        VerticalLayout {
            alignment: center;
            spacing: 5px;
            padding: 8px;

            Text {
                text: "GAME OVER";
                font-size: 18px;
                font-weight: 800;
                color: root.ink;
                horizontal-alignment: center;
            }

            Text {
                text: "Cancer cells destroyed: " + root.cancer-score;
                font-size: 11px;
                font-weight: 600;
                color: Theme.game-green;
                horizontal-alignment: center;
            }

            Text {
                text: "Click to restart";
                font-size: 10px;
                color: root.ink;
                opacity: 0.5;
                horizontal-alignment: center;
            }
        }
    }

    // Unified input: click or Space to jump/restart; Space also disables auto-jump
    fs := FocusScope {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;

        key-pressed(event) => {
            if (event.text == " " && !root.game-over) {
                if (root.auto-jump) {
                    root.cancer-score = 0;
                    root.banner-opacity = 1.0;
                }
                root.auto-jump = false;
                if (root.jump-frame-counter == -1) {
                    root.jump-frame-counter = 0;
                }
                accept
            } else {
                reject
            }
        }

        TouchArea {
            clicked => {
                fs.focus();
                if (root.game-over) {
                    root.game-over = false;
                    root.auto-jump = true;
                    root.cancer-score = 0;
                    root.ball-y-offset = 0px;
                    root.jump-frame-counter = -1;
                    root.obs1-x = 460px;
                    root.obs2-x = 730px;
                    root.obs1-type = 1;
                    root.obs2-type = 2;
                }
            }
        }
    }
}
