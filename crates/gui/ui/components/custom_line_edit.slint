import { Theme } from "../style.slint";
export component CustomLineEdit {
    in-out property <string> text <=> input.text;
    in property <string> placeholder-text;
    in property <length> font-size;
    in property <TextHorizontalAlignment> horizontal-alignment;

    callback edited(string);
    callback accepted(string);

    // The main container replaces the default background and borders
    Rectangle {
        background: Theme.bg;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.bg;

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            padding-top: 6px;
            padding-bottom: 6px;
            height: 26px;

            // The actual interactive text element
            input := TextInput {
                font-size: root.font-size;
                vertical-alignment: center;
                horizontal-alignment: root.horizontal-alignment;
                height: 26px;

                // Fire callbacks when text changes or Enter is pressed
                edited => {
                    root.edited(self.text);
                }
                accepted => {
                    root.accepted(self.text);
                }
            }
        }

        // Placeholder text logic
        if input.text == "" && !input.has-focus: Text {
            text: root.placeholder-text;
            x: 8px;
            y: (parent.height - self.height) / 2;
            color: Theme.text-faint;
            font-size: 14px;
        }
    }
}
